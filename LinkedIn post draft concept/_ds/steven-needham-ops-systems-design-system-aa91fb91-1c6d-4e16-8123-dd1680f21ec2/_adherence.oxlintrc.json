{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/timeline/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|label|key|ref|className|style|children)$/]",
        "message": "<FooterLink> doesn't accept that prop. Declared props: href, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='LinkButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|variant|target|children|key|ref|className|style|children)$/]",
        "message": "<LinkButton> doesn't accept that prop. Declared props: href, variant, target, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LinkButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ops|sys|paper)$/]",
        "message": "<LinkButton> variant must be one of 'ops' | 'sys' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBarLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|label|key|ref|className|style|children)$/]",
        "message": "<NavBarLink> doesn't accept that prop. Declared props: href, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|size|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:h2|footer)$/]",
        "message": "<SectionHeading> size must be one of 'h2' | 'footer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StopCardLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|label|key|ref|className|style|children)$/]",
        "message": "<StopCardLink> doesn't accept that prop. Declared props: href, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackLegendItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:track|label|key|ref|className|style|children)$/]",
        "message": "<TrackLegendItem> doesn't accept that prop. Declared props: track, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackLegendItem'] > JSXAttribute[name.name='track'] > Literal[value!=/^(?:ops|sys)$/]",
        "message": "<TrackLegendItem> track must be one of 'ops' | 'sys'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "FooterLink": {
        "replaces": []
      },
      "LinkButton": {
        "replaces": []
      },
      "NavBarLink": {
        "replaces": []
